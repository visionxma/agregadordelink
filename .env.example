# ==================================================================
# LinkHub — Environment Variables
# ==================================================================
# Cole essas vars na Vercel: Settings → Environment Variables
# Marque os 3 ambientes: Production, Preview, Development
# ==================================================================

# ============== OBRIGATÓRIAS (senão o build quebra) ==============

# Postgres (Supabase pooler recomendado)
# Supabase → Settings → Database → Connection string → "Session pooler"
DATABASE_URL="postgresql://postgres.XXX:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Better Auth — secret random (mínimo 32 chars)
# Gera com: openssl rand -base64 32
BETTER_AUTH_SECRET="cole-aqui-um-secret-aleatorio-de-no-minimo-32-chars"

# URL pública do deploy (sem barra no final)
# Em produção: https://seudominio.com OU https://seuprojeto.vercel.app
BETTER_AUTH_URL="https://seuprojeto.vercel.app"

# Mesmo valor acima, exposto pro cliente (sitemap, auth-client)
NEXT_PUBLIC_APP_URL="https://seuprojeto.vercel.app"

# Hosts que servem o app (separados por vírgula, sem https://)
# Middleware usa pra diferenciar custom domains de usuários
APP_HOSTS="seuprojeto.vercel.app,seudominio.com,www.seudominio.com"


# ============== OPCIONAIS (cada feature desliga sem sua var) =======

# --- Upload de imagem (Supabase Storage) ---
# 1. Supabase → Storage → New bucket: "linkhub-uploads" (Public)
# 2. Cole URL + service_role key abaixo
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Emails transacionais (Resend) ---
# https://resend.com → crie API key + domínio verificado
RESEND_API_KEY=""
EMAIL_FROM="LinkHub <nao-responda@seudominio.com>"
# "disabled" desativa; qualquer outro valor (ou vazio) exige verificação quando Resend está configurado
EMAIL_VERIFICATION=""

# --- OAuth Google (opcional) ---
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://seudominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Billing (Stripe) ---
# Crie produtos e prices em https://dashboard.stripe.com/products
STRIPE_SECRET_KEY=""
# Webhook signing secret — configure endpoint /api/stripe/webhook na Stripe
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

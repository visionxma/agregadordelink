# ============== OBRIGATÓRIOS ==============

# Postgres (Neon, Supabase, etc)
DATABASE_URL="postgresql://user:password@host:5432/db"

# Better Auth
BETTER_AUTH_SECRET="gere-com-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# ============== OPCIONAIS ==============

# --- Upload de imagem (Supabase Storage) ---
# Crie um bucket público "linkhub-uploads" no seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Emails transacionais (Resend) ---
# https://resend.com — crie API key e domínio verificado
RESEND_API_KEY=""
EMAIL_FROM="LinkHub <nao-responda@seudominio.com>"
# "required" pra forçar verificação de email no signup. Qualquer outro valor desabilita.
EMAIL_VERIFICATION=""

# --- OAuth Google (opcional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Billing (Stripe) ---
# Crie produtos e prices em https://dashboard.stripe.com/test/products
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# --- Custom domains ---
# Lista separada por vírgula dos hosts que servem a aplicação (não custom domains)
# Em produção: "linkhub.app,www.linkhub.app"
APP_HOSTS="localhost:3000,linkhub.app"
